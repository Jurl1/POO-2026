QTabBar::tab:selected { color: #f0a500; border-bottom: 2px solid #f0a500; background-color: #141416; }
QTabBar::tab:hover:!selected { color: #c8c6c0; }
QPlainTextEdit { background-color: #111113; border: 1px solid #2a2a2e; border-radius: 4px; color: #d8d6d0; padding: 10px; selection-background-color: #f0a500; selection-color: #0e0e0f; }
QPlainTextEdit:focus { border: 1px solid #f0a500; }
QLineEdit { background-color: #111113; border: 1px solid #2a2a2e; border-radius: 4px; color: #e8e6e0; padding: 6px 10px; }
QLineEdit:focus { border: 1px solid #f0a500; }
QGroupBox { border: 1px solid #2a2a2e; border-radius: 4px; margin-top: 14px; padding-top: 8px; font-size: 11px; letter-spacing: 1px; color: #6b6b70; }
QGroupBox::title { subcontrol-origin: margin; left: 12px; padding: 0 6px; }
QScrollBar:vertical { background: #111113; width: 8px; border: none; }
QScrollBar::handle:vertical { background: #2a2a2e; border-radius: 4px; min-height: 20px; }
QScrollBar::handle:vertical:hover { background: #f0a500; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0px; }
QStatusBar { background-color: #0a0a0b; color: #6b6b70; border-top: 1px solid #2a2a2e; font-size: 11px; }
QFrame#frameHeader { background-color: #0a0a0b; border-bottom: 1px solid #f0a500; }
QFrame#frameControles { background-color: #0a0a0b; border-bottom: 1px solid #2a2a2e; }
QLabel#lblAppTitle { color: #f0a500; font-size: 18px; font-weight: bold; letter-spacing: 3px; }
QLabel#lblAppSubtitle { color: #6b6b70; font-size: 11px; letter-spacing: 1px; }
QLabel#lblTema { color: #6b6b70; font-size: 11px; letter-spacing: 1px; }
